# Google Gemini API Key - Required for AI features
# Get free key at: https://makersuite.google.com/app/apikey
# Vite requires VITE_ prefix to expose to browser
VITE_GEMINI_API_KEY=sk_your_gemini_api_key_here

# GitHub Personal Access Token - Optional but recommended
# Get token at: https://github.com/settings/tokens
# Higher rate limits with token (5000 req/hour vs 60 req/hour)
# Scopes needed: public_repo, read:repo_hook (optional)
VITE_GITHUB_TOKEN=ghp_your_github_token_here

# Optional: Custom app URL for deployment
# Used for self-referential links and API endpoints
# VITE_APP_URL=https://yourdomain.com
